</xsd:annotation>
</xsd:element>
<xsd:element name="IIC00180" type="gen:kingaku" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"一者当たり基準限度超過額の合計額"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="IIC00190" type="gen:kingaku" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"差引金額"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="IIC00200" type="gen:kingaku" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"会費収入"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="IIC00210" type="gen:kingaku" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"国の補助金等の金額"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="IIC00220" type="gen:kingaku" minOccurs="0">
