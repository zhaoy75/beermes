<xsd:appinfo>"個人番号又は法人番号"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
</xsd:sequence>
</xsd:complexType><xsd:complexType name="AAK00000021-5-0type">
<xsd:sequence>

<xsd:element name="AAK00010" type="gen:address">
