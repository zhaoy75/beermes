</xsd:simpleType>

<xsd:simpleType name="AMB00080-2-0Rtype">
    <xsd:restriction base="gen:str">
        <xsd:maxLength value="10"/>
    </xsd:restriction>
</xsd:simpleType>


<xsd:complexType name="AMB00050-2-0type">
<xsd:simpleContent>
