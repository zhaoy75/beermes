<xsd:appinfo>"添付する証明書部数"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="BIB00050" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"証明書番号"</xsd:appinfo>
</xsd:annotation>
<xsd:complexType>
<xsd:sequence>
<xsd:element name="BIB00060" type="BIB00060-1-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"記号"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="BIB00070" type="BIB00070-1-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"第__号"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
</xsd:sequence>
</xsd:complexType>
</xsd:element>
</xsd:sequence>
</xsd:complexType>
</xsd:element>
<xsd:element name="BIB00080" type="BIB00080-1-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"(2)証明書の交付を受ける要件等に該当しなくなったことの事情の詳細"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
</xsd:sequence>
