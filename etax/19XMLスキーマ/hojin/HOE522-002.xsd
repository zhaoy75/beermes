<xsd:appinfo>"(1)のうちないものとされる金額"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="FVI00040" type="gen:gaika" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"(2)のうちないものとされる金額"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="FVI00050" type="gen:gaika" minOccurs="0">
