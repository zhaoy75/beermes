</xsd:annotation>
</xsd:element>
</xsd:sequence>
<xsd:attribute name="VR"
type="HOZ150-1-0VRtype"
use="required"/>
<xsd:attributeGroup ref="gen:FormAttribute"/>
</xsd:complexType>
</xsd:element>
</xsd:sequence>
</xsd:group>

<xsd:complexType name="GDA00000-1-0type">
<xsd:sequence>

<xsd:element name="GDA00010" type="GDA00010-1-0type" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"番号"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="GDA00020" type="GDA00020-1-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"資産の区分"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="GDA00030" type="GDA00030-1-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"採掘予定数量"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="GDA00040" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"年間採掘数量"</xsd:appinfo>
</xsd:annotation>
<xsd:complexType>
<xsd:sequence>
<xsd:element name="GDA00050" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"最近における年間採掘数量"</xsd:appinfo>
</xsd:annotation>
<xsd:complexType>
<xsd:sequence>
<xsd:element name="GDA00060" type="GDA00060-1-0type" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"採掘月数"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="GDA00070" type="GDA00070-1-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"採掘量"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="GDA00080" type="GDA00080-1-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"年換算平均採掘量"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
</xsd:sequence>
</xsd:complexType>
</xsd:element>
<xsd:element name="GDA00090" type="GDA00090-1-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"今後予想される年間採掘数量"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
</xsd:sequence>
</xsd:complexType>
</xsd:element>
<xsd:element name="GDA00100" type="GDA00100-1-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"当該鉱区等に属する設備の採掘能力"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="GDA00110" type="GDA00110-1-0type" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"採掘従業員数"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="GDA00120" type="GDA00120-1-0type" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"認定を受けようとする年数"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
</xsd:sequence>
</xsd:complexType>

<xsd:simpleType name="GDA00010-1-0Rtype">
    <xsd:restriction base="gen:nonNegativeType">
        <xsd:pattern value="\d?\d"/>
    </xsd:restriction>
</xsd:simpleType>

<xsd:complexType name="GDA00020-1-0Rtype">
    <xsd:complexContent>
        <xsd:restriction base="gen:kubun">
            <xsd:sequence>
                <xsd:element name="kubun_CD">
                    <xsd:simpleType>
                        <xsd:restriction base="gen:kubun_CD">
                            <xsd:enumeration value="1"/><xsd:enumeration value="2"/><xsd:enumeration value="3"/><xsd:enumeration value="4"/>
                        </xsd:restriction>
                    </xsd:simpleType>
                </xsd:element>
                <xsd:element name="kubun_NM" minOccurs="0">
                    <xsd:simpleType>
                        <xsd:restriction base="gen:kubun_NM">
                        </xsd:restriction>
                    </xsd:simpleType>
                </xsd:element>
            </xsd:sequence>
        </xsd:restriction>
    </xsd:complexContent>
</xsd:complexType>

<xsd:simpleType name="GDA00030-1-0Rtype">
    <xsd:restriction base="gen:str">
        <xsd:maxLength value="10"/>
    </xsd:restriction>
</xsd:simpleType>

<xsd:simpleType name="GDA00060-1-0Rtype">
    <xsd:restriction base="gen:nonNegativeType">
        <xsd:pattern value="\d?\d?\d"/>
    </xsd:restriction>
</xsd:simpleType>

<xsd:simpleType name="GDA00070-1-0Rtype">
    <xsd:restriction base="gen:str">
        <xsd:maxLength value="10"/>
    </xsd:restriction>
</xsd:simpleType>

<xsd:simpleType name="GDA00080-1-0Rtype">
