<xsd:complexType name="IIA00000-1-0type">
<xsd:sequence>

<xsd:element name="IIA00010" type="IIA00010-1-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"1　未成年と思われる者に対して、年齢確認を行っている。"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="IIA00020" type="IIA00020-1-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"2　夜間(23時から翌日5時)において指名し、配置している「酒類販売管理者に代わる責任者」は成年者である。"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="IIA00030" type="IIA00030-1-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"3　直近1年以内に未成年者の飲酒防止に関するポスターを掲示したことがある。"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="IIA00040" type="IIA00040-1-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"4　「その他の取組」の概要"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
</xsd:sequence>
</xsd:complexType><xsd:complexType name="IIB00000-1-0type">
<xsd:sequence>

<xsd:element name="IIB00010" type="IIB00010-1-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"1　酒類の陳列場所、店頭、レジ等に「飲酒運転は禁止されている」旨の表示を行っている。"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="IIB00020" type="IIB00020-1-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"2　自動車等で来店したと思われる者に対して「飲酒運転をしないように」といった一声運動を行っている。"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="IIB00030" type="IIB00030-1-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"3　直近1年以内に飲酒運転の防止に関するポスターを掲示したことがある。"</xsd:appinfo>
