</xsd:annotation>
</xsd:element>
<xsd:element name="CRB00000" type="gen:TEISYUTSU_DAYref" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"提出年月日"</xsd:appinfo>
</xsd:annotation>
</xsd:element><xsd:element name="CRC00000" type="CRC00000-1-0type" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"納税者等部"</xsd:appinfo>
</xsd:annotation>
</xsd:element>

<xsd:element name="CRD00000" type="CRD00000-1-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"租税特別措置法　条文"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="CRE00000" type="gen:yymmdd" minOccurs="0">
