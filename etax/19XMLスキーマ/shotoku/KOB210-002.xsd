<xsd:appinfo>"取得に要する金額の見込額"</xsd:appinfo>
</xsd:annotation>
<xsd:complexType>
<xsd:sequence>
<xsd:element name="BUK00040" type="gen:kingaku" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"見込額"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="BUK00050" minOccurs="0" maxOccurs="4">
