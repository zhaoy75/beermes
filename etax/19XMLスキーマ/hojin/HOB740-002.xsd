    </xsd:restriction>
</xsd:simpleType>

<xsd:simpleType name="GQC00000-2-0Rtype">
    <xsd:restriction base="gen:str">
        <xsd:maxLength value="15"/>
    </xsd:restriction>
</xsd:simpleType>



<xsd:complexType name="GQB00070-2-0type">
<xsd:simpleContent>
