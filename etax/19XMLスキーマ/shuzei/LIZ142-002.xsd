</xsd:annotation>
</xsd:element>
<xsd:element name="IJA00090" type="IJA00090-2-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"連絡先の所在地及び電話番号"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="IJA00100" type="IJA00100-2-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"販売停止時間"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
</xsd:sequence>
</xsd:complexType>
</xsd:element>
<xsd:element name="IJA00110" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"店外の改良型以外の酒類自動販売機の撤廃予定の状況等"</xsd:appinfo>
</xsd:annotation>
<xsd:complexType>
<xsd:sequence>
<xsd:element name="IJA00120" type="IJA00120-2-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"(1) 撤廃の予定等"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="IJA00130" type="gen:yymmdd" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"(2) (1)で「イ」又は「ロ」を選択した場合には撤廃予定日又は改良型への切替予定日"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
</xsd:sequence>
</xsd:complexType>
</xsd:element>
<xsd:element name="IJA00140" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"表示基準を遵守しない理由"</xsd:appinfo>
</xsd:annotation>
<xsd:complexType>
<xsd:sequence>
<xsd:element name="IJA00150" type="IJA00150-2-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"(1) 表示基準を遵守しない場合その理由"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="IJA00160" type="gen:yymmdd" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"(2) 表示基準を遵守した表示を行う予定日"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
</xsd:sequence>
</xsd:complexType>
</xsd:element>
<xsd:element name="IJA00170" type="IJA00170-2-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"販売停止等のためのタイマーの設置の有無"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="IJA00180" type="IJA00180-2-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"セレクトボタン部分への酒類である旨の表示の有無"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
</xsd:sequence>
</xsd:complexType><xsd:complexType name="IJB00000-2-0type">
<xsd:sequence>

<xsd:element name="IJB00010" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"(3)　(1)で「ニ」を選択した場合には撤廃しない具体的な理由"</xsd:appinfo>
</xsd:annotation>
<xsd:complexType>
<xsd:sequence>
<xsd:element name="IJB00020" type="IJB00020-2-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"a 経済的な理由(売上高の減少、撤廃・改良型切替の費用負担困難)"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="IJB00030" type="IJB00030-2-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"b 周辺地域の酒販店が撤去していない"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="IJB00040" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"c その他"</xsd:appinfo>
</xsd:annotation>
<xsd:complexType>
<xsd:sequence>
<xsd:element name="IJB00050" type="IJB00050-2-0Rtype" minOccurs="0">
