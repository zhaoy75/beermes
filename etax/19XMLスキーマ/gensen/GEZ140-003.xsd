<xsd:element name="BHC00070" type="gen:yymmdd" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"(5)会社法第933条第１項、旧商法第479条第１項、旧有限会社法第76条又は民法第49条第１項に規定する登記をした年月日"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="BHC00080" type="BHC00080-3-0Rtype" minOccurs="0">
