<xsd:appinfo>"事業年度"</xsd:appinfo>
</xsd:annotation>
<xsd:complexType>
<xsd:sequence>
<xsd:element name="VWA00020" type="gen:JIGYO_NENDO_FROMref" minOccurs="0">
