</xsd:annotation>
</xsd:element>
<xsd:element name="UED00030" type="UED00030-3-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"(4)及び(5)の株式数の合計"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="UED00040" type="UED00040-3-0type" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"発行済株式総数(自己が有する自己の株式数を除く)のうちに占める割合"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
</xsd:sequence>
