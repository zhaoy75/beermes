<?xml version="1.0" encoding="UTF-8" ?>
<xsd:schema targetNamespace="http://xml.e-tax.nta.go.jp/XSD/shisan"
xmlns="http://xml.e-tax.nta.go.jp/XSD/shisan"
xmlns:gen="http://xml.e-tax.nta.go.jp/XSD/general" xmlns:kyo="http://xml.e-tax.nta.go.jp/XSD/kyotsu"

xmlns:xsd="http://www.w3.org/2001/XMLSchema" elementFormDefault="qualified" attributeFormDefault="unqualified" version="1.0" > 
<xsd:annotation> 
<xsd:documentation> 
様式名：贈与税・相続税の納税猶予の継続届出書
version：1.1
Date：2006年08月03日
</xsd:documentation> 
</xsd:annotation> 

<!-- import -->
<xsd:import namespace="http://xml.e-tax.nta.go.jp/XSD/general" schemaLocation="../general/General.xsd"/>

<!-- version -->
<xsd:simpleType name="KSZ190-1-1VRtype"><xsd:restriction base="xsd:string"><xsd:enumeration value="1.0"/><xsd:enumeration value="1.1"/></xsd:restriction></xsd:simpleType>

<xsd:group name="KSZ190-1-1group">
<xsd:sequence>
<xsd:element name="KSZ190">
<xsd:complexType>
<xsd:sequence>

<xsd:element name="BNA00000" type="gen:ZEIMUSHOref" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"提出先税務署"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="BNB00000" type="gen:TEISYUTSU_DAYref" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"提出年月日"</xsd:appinfo>
</xsd:annotation>
</xsd:element><xsd:element name="BNC00000" type="BNC00000-1-1type" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"納税者等部"</xsd:appinfo>
</xsd:annotation>
</xsd:element>

<xsd:element name="BND00000" type="gen:yymmdd" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"農地等の贈与を受けた・相続(遺贈)があった年月日"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="BNE00000" type="gen:address" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"贈与者・被相続人住所"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="BNF00000" type="gen:name" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"贈与者・被相続人氏名"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="BNG00000" type="gen:yymmdd" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"贈与者・被相続人生年月日"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="BNH00000" type="gen:kingaku" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"1.納付すべき贈与税額・相続税額のうち納税の猶予の適用を受けた贈与税額・相続税額"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="BNI00000" type="gen:kingaku" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"2. 1のうちこの届出書の提出までに特例農地等の譲渡等をしたため、既に納税の猶予が確定し納付した贈与税額・相続税額"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="BNJ00000" type="gen:kingaku" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"3. 1のうち届出日現在において納税の猶予を受けている贈与税額・相続税額(1-2の金額)"</xsd:appinfo>
</xsd:annotation>
</xsd:element><xsd:element name="BNK00000" type="BNK00000-1-1type" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"4."</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="BNL00000" type="BNL00000-1-1type" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"関与税理士欄"</xsd:appinfo>
</xsd:annotation>
</xsd:element>

</xsd:sequence>
<xsd:attribute name="VR"
type="KSZ190-1-1VRtype"
use="required"/>
<xsd:attributeGroup ref="gen:FormAttribute"/>
</xsd:complexType>
</xsd:element>
</xsd:sequence>
</xsd:group>

<xsd:complexType name="BNC00000-1-1type">
<xsd:sequence>

<xsd:element name="BNC00010" type="gen:NOZEISHA_ZIPref" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"郵便番号"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="BNC00020" type="gen:NOZEISHA_ADRref" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"住所"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="BNC00030" type="gen:NOZEISHA_NMref" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"氏名"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="BNC00040" type="gen:NOZEISHA_TELref" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"電話番号"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
</xsd:sequence>
</xsd:complexType><xsd:complexType name="BNK00000-1-1type">
<xsd:sequence>

<xsd:element name="BNK00010" type="gen:yymmdd" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"使用貸借権利設定年月日"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="BNK00020" type="BNK00020-1-1Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"推定相続人等区分"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="BNK00030" type="gen:name" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"推定相続人等氏名"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
</xsd:sequence>
</xsd:complexType><xsd:complexType name="BNL00000-1-1type">
<xsd:sequence>

<xsd:element name="BNL00010" type="gen:DAIRI_NMref" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"関与税理士"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="BNL00020" type="gen:DAIRI_TELref" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"電話番号"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
</xsd:sequence>
</xsd:complexType>


<xsd:complexType name="BNK00020-1-1Rtype">
    <xsd:complexContent>
        <xsd:restriction base="gen:kubun">
            <xsd:sequence>
                <xsd:element name="kubun_CD">
                    <xsd:simpleType>
                        <xsd:restriction base="gen:kubun_CD">
                            <xsd:enumeration value="1"/><xsd:enumeration value="2"/>
                        </xsd:restriction>
                    </xsd:simpleType>
                </xsd:element>
                <xsd:element name="kubun_NM" minOccurs="0">
                    <xsd:simpleType>
                        <xsd:restriction base="gen:kubun_NM">
                        </xsd:restriction>
                    </xsd:simpleType>
                </xsd:element>
            </xsd:sequence>
        </xsd:restriction>
    </xsd:complexContent>
</xsd:complexType>



</xsd:schema>
