<xsd:element name="BLD00120" type="gen:kingaku" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"( (7) + (8) + (9) )"</xsd:appinfo>
<xsd:appinfo>horizontal</xsd:appinfo>
</xsd:annotation>
</xsd:element>
</xsd:sequence>
</xsd:complexType>
</xsd:element>
<xsd:element name="BLD00130" type="gen:kingaku" minOccurs="0">
<xsd:annotation>
