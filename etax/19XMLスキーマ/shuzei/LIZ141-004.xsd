</xsd:annotation>
</xsd:element>
<xsd:element name="III00060" type="III00060-4-0type" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"指名の基準"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
</xsd:sequence>
</xsd:complexType>
</xsd:element>
</xsd:sequence>
</xsd:complexType>


