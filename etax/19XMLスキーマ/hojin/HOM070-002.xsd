</xsd:annotation>
</xsd:element>
<xsd:element name="LIB00310" type="LIB00310-2-1Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"経営革新のための事業の内容"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="LIB00320" type="LIB00320-2-1Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"当期末における事業の状況"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="LIB00330" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"添付書類"</xsd:appinfo>
</xsd:annotation>
<xsd:complexType>
<xsd:sequence>
<xsd:element name="LIB00340" type="LIB00340-2-1Rtype" minOccurs="0">
