<xsd:annotation>
<xsd:appinfo>"中間申告における災害損失欠損金の繰戻し額"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="GQB00090" type="gen:kingaku" minOccurs="0">
