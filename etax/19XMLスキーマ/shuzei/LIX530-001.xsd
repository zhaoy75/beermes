<xsd:complexType>
<xsd:sequence>
<xsd:element name="AYA00000" type="AYA00000-1-0type" minOccurs="0" maxOccurs="11">
<xsd:annotation>
<xsd:appinfo>"負担金の賦課基準の内容 繰り返し"</xsd:appinfo>
</xsd:annotation>
