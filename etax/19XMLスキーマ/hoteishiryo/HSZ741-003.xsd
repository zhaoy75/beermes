<xsd:appinfo>"住所(居所)"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="GBD00020" type="gen:name">
<xsd:annotation>
<xsd:appinfo>"氏名"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="GBD00030" type="gen:bango" minOccurs="0">
