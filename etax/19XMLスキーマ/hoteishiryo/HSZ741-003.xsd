</xsd:annotation>
</xsd:element>
</xsd:sequence>
</xsd:complexType><xsd:complexType name="GBE00000-3-0type">
<xsd:sequence>

<xsd:element name="GBE00010" type="GBE00010-3-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"信託受益権の種別"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="GBE00020" type="GBE00020-3-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"信託財産の種類"</xsd:appinfo>
