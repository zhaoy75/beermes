<xsd:appinfo>"総売上高"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="IIJ00020" type="gen:kingaku" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"内酒類小売による売上高"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="IIJ00030" type="gen:kingaku" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"売上総利益"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="IIJ00040" type="gen:kingaku" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"内酒類小売による売上総利益"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="IIJ00050" type="gen:kingaku" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"営業利益"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="IIJ00060" type="gen:kingaku" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"税引前純利益"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="IIJ00070" type="gen:kingaku" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"酒類に係る受取リベート"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
</xsd:sequence>
