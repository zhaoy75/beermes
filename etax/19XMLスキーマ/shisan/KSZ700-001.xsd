</xsd:annotation>
</xsd:element><xsd:element name="CRF00000" type="CRF00000-1-0type" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"贈与者・被相続人"</xsd:appinfo>
</xsd:annotation>
</xsd:element>

<xsd:element name="CRG00000" type="gen:yymmdd" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"１　経営(贈与・相続)報告基準日"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="CRH00000" type="gen:kingaku" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"２　１の基準日における猶予中贈与税・相続税額"</xsd:appinfo>
</xsd:annotation>
</xsd:element><xsd:element name="CRI00000" type="CRI00000-1-0type" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"３　１の基準日において有する特例(受贈・相続)非上場株式等の数又は金額"</xsd:appinfo>
</xsd:annotation>
</xsd:element>

<xsd:element name="CRJ00000" type="gen:name" minOccurs="0">
