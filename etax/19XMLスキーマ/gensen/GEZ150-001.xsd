</xsd:annotation>
</xsd:element>
<xsd:element name="BIA00100" type="gen:DAIHYO_NMref" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"代表者その他の責任者の氏名"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
</xsd:sequence>
</xsd:complexType>
</xsd:element>
<xsd:element name="BIA00110" type="gen:n-kana" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"納税管理人の氏名フリガナ"</xsd:appinfo>
