</xsd:documentation> 
</xsd:annotation> 

<!-- import -->
<xsd:import namespace="http://xml.e-tax.nta.go.jp/XSD/general" schemaLocation="../general/General.xsd"/>

<!-- version -->
<xsd:simpleType name="HOZ150-1-0VRtype"><xsd:restriction base="xsd:string"><xsd:enumeration value="1.0"/></xsd:restriction></xsd:simpleType>

<xsd:group name="HOZ150-1-0group">
<xsd:sequence>
<xsd:element name="HOZ150">
<xsd:complexType>
<xsd:sequence>
<xsd:element name="GDA00000" type="GDA00000-1-0type" minOccurs="0" maxOccurs="6">
<xsd:annotation>
<xsd:appinfo>"認定を受けようとする耐用年数の算定に関する明細書　繰り返し"</xsd:appinfo>
</xsd:annotation>
</xsd:element>

<xsd:element name="GDB00000" type="GDB00000-1-0Rtype" minOccurs="0">
<xsd:annotation>
