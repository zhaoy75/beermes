<xsd:complexType name="IJC00000-7-0type">
<xsd:sequence>

<xsd:element name="IJC00010" type="IJC00010-7-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"1　20歳未満と思われる者に対して、年齢確認を行っている。"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="IJC00020" type="IJC00020-7-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"2　20歳未満の者の飲酒防止を啓発するための店内放送、店頭・売場等への表示、ポスターの掲示等を行っている。"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
</xsd:sequence>
</xsd:complexType><xsd:complexType name="IJD00000-7-0type">
<xsd:sequence>

<xsd:element name="IJD00010" type="IJD00010-7-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"1　酒類の陳列場所、店頭、レジ等に「飲酒運転は禁止されている」旨の表示又は飲酒運転の防止に関するポスターの掲示を行っている等、飲酒運転防止のための取組を行っている。"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="IJD00020" type="IJD00020-7-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"2　自動車等で来店したと思われる者に対して「飲酒運転をしないように」といった一声運動を行っている。"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
</xsd:sequence>
</xsd:complexType><xsd:complexType name="IJE00000-7-0type">
<xsd:sequence>

<xsd:element name="IJE00010" type="IJE00010-7-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"1　リターナブルびん(ビールびんや清酒の一升びんなどの繰り返し使用されるびん)を使った酒類を販売している。"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="IJE00020" type="IJE00020-7-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"2　リターナブルびんの回収を行っている。"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="IJE00030" type="IJE00030-7-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"3　消費者が販売場に容器を持参した場合の回収マニュアルを定めており、これに基づき酒類容器のリサイクルに積極的に取り組んでいる。"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="IJE00040" type="IJE00040-7-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"4　酒類の陳列場所、店頭、レジ等に「リターナブルびんの回収を行っている」旨の表示を行っている。"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
</xsd:sequence>
</xsd:complexType><xsd:complexType name="IJG00000-7-0type">
<xsd:sequence>

<xsd:element name="IJG00010" type="IJG00010-7-0type" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"酒類販売管理者に代わる責任者の人数"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="IJG00020" minOccurs="0" maxOccurs="8">
<xsd:annotation>
