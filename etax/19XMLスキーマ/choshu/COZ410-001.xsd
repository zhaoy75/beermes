<xsd:element name="AHB00110" type="AHB00110-1-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"２差押えを解除すべき財産"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="AHB00120" minOccurs="0">
