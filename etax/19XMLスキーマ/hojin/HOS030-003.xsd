<xsd:element name="UEF00020" type="UEF00020-3-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"区分"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="UEF00030" type="UEF00030-3-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"保有株式数又は出資金額"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="UEF00040" type="UEF00040-3-0type" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"発行済株式の総数又は出資の総額に対する保有株式数又は出資金額の割合"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="UEF00050" type="UEF00050-3-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"出資関係図における一連番号"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
