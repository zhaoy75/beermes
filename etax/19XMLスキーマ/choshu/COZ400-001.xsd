</xsd:annotation>
</xsd:element>
<xsd:element name="AGB00130" type="AGB00130-1-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"（２）異議申立ての対象となった処分"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
</xsd:sequence>
</xsd:complexType>
</xsd:element>
