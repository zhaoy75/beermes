</xsd:annotation>
</xsd:element>
<xsd:element name="UED00000" type="UED00000-3-0type" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"法人税法施行令第14条の6第2項により読み替えられた第4条の2第2項に規定する株式の状況"</xsd:appinfo>
</xsd:annotation>
</xsd:element>

<xsd:element name="UEE00000" type="UEE00000-3-0Rtype" minOccurs="0">
