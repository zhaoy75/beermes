</xsd:annotation>
</xsd:element>

<xsd:element name="EIE00000" type="EIE00000-3-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"外国証券取引口座番号"</xsd:appinfo>
</xsd:annotation>
</xsd:element><xsd:element name="EIF00000" type="EIF00000-3-0type" minOccurs="0" maxOccurs="5">
