{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/mes/recipe_body_v1.json",
  "title": "MES Recipe Body v1",
  "description": "Schema for mes.mst_recipe_version.recipe_body_json.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "base", "materials", "flow"],
  "properties": {
    "schema_version": {
      "const": "recipe_body_v1"
    },
    "recipe_info": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "recipe_type": {
          "type": "string",
          "minLength": 1
        },
        "industry_type": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "batch_strategy": {
          "type": "string",
          "enum": ["fixed", "scale_to_order", "campaign"]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "base": {
      "type": "object",
      "additionalProperties": false,
      "required": ["quantity", "uom_code"],
      "properties": {
        "quantity": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "uom_code": {
          "$ref": "#/$defs/code"
        },
        "scaling_method": {
          "type": "string",
          "enum": ["linear", "fixed", "formula"]
        },
        "rounding_rule": {
          "type": "string"
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "primary": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/outputSpec"
          }
        },
        "co_products": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/outputSpec"
          }
        },
        "waste": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/outputSpec"
          }
        }
      }
    },
    "materials": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required"],
      "properties": {
        "required": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/materialRequirement"
          }
        },
        "optional": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/materialRequirement"
          }
        }
      }
    },
    "flow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["steps"],
      "properties": {
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/flowStep"
          }
        },
        "dependencies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stepDependency"
          }
        }
      }
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "global_checks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/qualityCheckRequirement"
          }
        },
        "release_criteria": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "storage_constraints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/storageConstraint"
      }
    },
    "documents": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/documentRef"
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "code": {
      "type": "string",
      "minLength": 1
    },
    "numericOrExpression": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "outputSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["output_code", "output_name", "output_type", "qty", "uom_code"],
      "properties": {
        "output_code": {
          "$ref": "#/$defs/code"
        },
        "output_name": {
          "type": "string",
          "minLength": 1
        },
        "output_type": {
          "type": "string",
          "enum": ["primary", "intermediate", "co_product", "waste"]
        },
        "qty": {
          "type": "number",
          "minimum": 0
        },
        "uom_code": {
          "$ref": "#/$defs/code"
        },
        "basis": {
          "type": "string",
          "enum": ["per_base", "fixed_per_batch", "yield_based"]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "materialRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["material_key", "material_role", "qty", "uom_code"],
      "properties": {
        "material_key": {
          "$ref": "#/$defs/code"
        },
        "material_name": {
          "type": "string"
        },
        "material_role": {
          "type": "string",
          "minLength": 1
        },
        "material_type_code": {
          "$ref": "#/$defs/code"
        },
        "material_code": {
          "$ref": "#/$defs/code"
        },
        "qty": {
          "type": "number",
          "minimum": 0
        },
        "uom_code": {
          "$ref": "#/$defs/code"
        },
        "basis": {
          "type": "string",
          "enum": ["per_base", "percent_of_base", "fixed_per_batch", "by_formula"]
        },
        "is_optional": {
          "type": "boolean"
        },
        "attr_values": {
          "type": "object",
          "additionalProperties": true
        },
        "allowed_substitutions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/code"
          }
        },
        "notes": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "anyOf": [
            {
              "required": ["material_type_code"]
            },
            {
              "required": ["material_code"]
            }
          ]
        }
      ]
    },
    "equipmentRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["equipment_type_code"],
      "properties": {
        "equipment_type_code": {
          "$ref": "#/$defs/code"
        },
        "equipment_template_code": {
          "$ref": "#/$defs/code"
        },
        "quantity": {
          "type": "integer",
          "minimum": 1
        },
        "capability_rules": {
          "type": "object",
          "additionalProperties": true
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "parameterTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["parameter_code"],
      "properties": {
        "parameter_code": {
          "$ref": "#/$defs/code"
        },
        "parameter_name": {
          "type": "string"
        },
        "target": {
          "$ref": "#/$defs/numericOrExpression"
        },
        "min": {
          "type": "number"
        },
        "max": {
          "type": "number"
        },
        "setpoint": {
          "$ref": "#/$defs/numericOrExpression"
        },
        "uom_code": {
          "$ref": "#/$defs/code"
        },
        "required": {
          "type": "boolean"
        },
        "sampling_frequency": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "qualityCheckRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["check_code"],
      "properties": {
        "check_code": {
          "$ref": "#/$defs/code"
        },
        "check_name": {
          "type": "string"
        },
        "sampling_point": {
          "type": "string"
        },
        "frequency": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "acceptance_criteria": {
          "type": "object",
          "additionalProperties": true
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "stepMaterialInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["material_key", "qty", "uom_code"],
      "properties": {
        "material_key": {
          "$ref": "#/$defs/code"
        },
        "qty": {
          "type": "number",
          "minimum": 0
        },
        "uom_code": {
          "$ref": "#/$defs/code"
        },
        "basis": {
          "type": "string",
          "enum": ["per_base", "fixed_per_batch", "yield_based"]
        },
        "consumption_mode": {
          "type": "string",
          "enum": ["exact", "estimate", "backflush"]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "stepMaterialOutput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["output_code", "output_name", "output_type", "qty", "uom_code"],
      "properties": {
        "output_code": {
          "$ref": "#/$defs/code"
        },
        "output_name": {
          "type": "string",
          "minLength": 1
        },
        "output_type": {
          "type": "string",
          "enum": ["primary", "intermediate", "co_product", "waste"]
        },
        "qty": {
          "type": "number",
          "minimum": 0
        },
        "uom_code": {
          "$ref": "#/$defs/code"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "storageConstraint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["constraint_code", "target_code", "max_hold_time", "uom_code"],
      "properties": {
        "constraint_code": {
          "$ref": "#/$defs/code"
        },
        "target_code": {
          "$ref": "#/$defs/code"
        },
        "storage_type": {
          "type": "string"
        },
        "max_hold_time": {
          "type": "number",
          "minimum": 0
        },
        "uom_code": {
          "$ref": "#/$defs/code"
        },
        "min_temp": {
          "type": "number"
        },
        "max_temp": {
          "type": "number"
        },
        "temp_uom_code": {
          "$ref": "#/$defs/code"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "documentRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["doc_code", "doc_type"],
      "properties": {
        "doc_code": {
          "$ref": "#/$defs/code"
        },
        "doc_type": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string"
        },
        "revision": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri-reference"
        },
        "required": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "flowStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step_code", "step_name", "step_no"],
      "properties": {
        "step_code": {
          "$ref": "#/$defs/code"
        },
        "step_name": {
          "type": "string",
          "minLength": 1
        },
        "step_no": {
          "type": "integer",
          "minimum": 1
        },
        "step_type": {
          "type": "string",
          "minLength": 1
        },
        "step_template_code": {
          "$ref": "#/$defs/code"
        },
        "instructions": {
          "type": "string"
        },
        "duration_sec": {
          "type": "integer",
          "minimum": 0
        },
        "material_inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stepMaterialInput"
          }
        },
        "material_outputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stepMaterialOutput"
          }
        },
        "equipment_requirements": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/equipmentRequirement"
          }
        },
        "parameters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/parameterTarget"
          }
        },
        "quality_checks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/qualityCheckRequirement"
          }
        },
        "hold_constraints": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/storageConstraint"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "stepDependency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from_step_code", "to_step_code", "relation_type"],
      "properties": {
        "from_step_code": {
          "$ref": "#/$defs/code"
        },
        "to_step_code": {
          "$ref": "#/$defs/code"
        },
        "relation_type": {
          "type": "string",
          "enum": ["finish_start", "start_start", "finish_finish", "start_finish"]
        },
        "lag_sec": {
          "type": "integer"
        }
      }
    }
  }
}
