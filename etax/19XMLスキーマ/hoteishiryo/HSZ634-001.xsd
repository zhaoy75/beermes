</xsd:annotation>
</xsd:element>

<xsd:element name="EKE00000" type="EKE00000-1-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"外国投資信託証券取引口座番号"</xsd:appinfo>
</xsd:annotation>
</xsd:element><xsd:element name="EKF00000" type="EKF00000-1-0type" minOccurs="0" maxOccurs="5">
