<xsd:complexType name="HGB00000-5-0type">
<xsd:sequence>

<xsd:element name="HGB00100" type="HGB00100-5-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"種類・構造"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
