</xsd:annotation>
</xsd:element>
<xsd:element name="BDB00020" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"(1)氏名(名称)又は住所若しくは居所の変更"</xsd:appinfo>
</xsd:annotation>
<xsd:complexType>
<xsd:sequence>
<xsd:element name="BDB00030" type="gen:yymmdd" minOccurs="0">
