<xsd:element name="GQB00040" type="gen:kingaku" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"他の通算法人の中間申告における発生災害損失欠損金額のうち通算対象外欠損金額以外の部分の金額の合計額"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="GQB00050" type="gen:kingaku" minOccurs="0">
