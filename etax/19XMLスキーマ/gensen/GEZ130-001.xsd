</xsd:element>
<xsd:element name="BDB00060" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"(2)証明書の交付を受ける要件に該当しないこととなったこと"</xsd:appinfo>
</xsd:annotation>
<xsd:complexType>
<xsd:sequence>
