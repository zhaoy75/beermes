</xsd:annotation>
</xsd:element>
<xsd:element name="BUN00000" type="BUN00000-2-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"国庫補助金等の交付に代わるべきものとして資産の交付を受けた事由"</xsd:appinfo>
</xsd:annotation>
</xsd:element><xsd:element name="BUJ00000" type="BUJ00000-2-0type" minOccurs="0">
