</xsd:annotation>
</xsd:element>
<xsd:element name="IJD00000" type="IJD00000-7-0type" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"飲酒運転防止関係"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="IJE00000" type="IJE00000-7-0type" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"酒類容器リサイクル関係"</xsd:appinfo>
</xsd:annotation>
</xsd:element>

<xsd:element name="IJF00000" type="IJF00000-7-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"適正飲酒を啓発するための店内放送、店頭・売場等への表示、ポスターの掲示等を行っている。"</xsd:appinfo>
</xsd:annotation>
</xsd:element><xsd:element name="IJG00000" type="IJG00000-7-0type" minOccurs="0">
<xsd:annotation>
