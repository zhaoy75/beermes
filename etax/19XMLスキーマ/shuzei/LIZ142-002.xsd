</xsd:annotation>
</xsd:element>
<xsd:element name="IJB00060" type="IJB00060-2-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"具体的な理由"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
</xsd:sequence>
</xsd:complexType>
</xsd:element>
</xsd:sequence>
</xsd:complexType>
</xsd:element>
