<xsd:appinfo>"（２）異議申立ての対象となった処分"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
</xsd:sequence>
</xsd:complexType>
</xsd:element>
<xsd:element name="AHB00150" type="AHB00150-1-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"４提供する担保財産"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
</xsd:sequence>
</xsd:complexType>

