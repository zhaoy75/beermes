<xsd:group ref="KSA011-14-0group" maxOccurs="1"/>
<xsd:group ref="KSA012-14-0group" maxOccurs="1"/>
</xsd:choice>
<xsd:group ref="KSA020-9-0group" minOccurs="1" maxOccurs="unbounded"/>
<xsd:group ref="KSB010-7-0group" minOccurs="0" maxOccurs="unbounded"/>
