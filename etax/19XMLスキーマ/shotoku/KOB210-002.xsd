</xsd:element>
<xsd:element name="BUK00000" type="BUK00000-2-0type" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"交付を受けた年の１２月３１日までに、国庫補助金等の返還を要しないことが確定しない場合"</xsd:appinfo>
</xsd:annotation>
</xsd:element>

<xsd:element name="BUL00000" type="BUL00000-2-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"その他参考事項"</xsd:appinfo>
</xsd:annotation>
