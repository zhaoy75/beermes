<xsd:appinfo>"明細　繰り返し"</xsd:appinfo>
</xsd:annotation>
<xsd:complexType>
<xsd:sequence>
<xsd:element name="AGB00020" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"被災前の全財産"</xsd:appinfo>
</xsd:annotation>
<xsd:complexType>
<xsd:sequence>
<xsd:element name="AGB00030" type="AGB00030-1-0Rtype" minOccurs="0">
