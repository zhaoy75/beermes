    </xsd:restriction>
</xsd:simpleType>

<xsd:simpleType name="BLD00035-1-0Rtype">
    <xsd:restriction base="xsd:nonNegativeInteger">
        <xsd:pattern value="\d"/>
    </xsd:restriction>
</xsd:simpleType>


<xsd:complexType name="BLD00035-1-0type">
<xsd:simpleContent>
