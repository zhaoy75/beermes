<xsd:complexType name="UEC00000-3-0type">
<xsd:sequence>

<xsd:element name="UEC00010" type="UEC00010-3-0Rtype" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"連結子法人となる法人が有する自己の株式数又は出資金額"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="UEC00020" type="UEC00020-3-0Rtype" minOccurs="0">
