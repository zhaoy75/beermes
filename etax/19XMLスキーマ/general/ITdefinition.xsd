		</xsd:restriction>
	</xsd:simpleType>
	
	<xsd:simpleType name="nametype">
		<xsd:restriction base="gen:name">
			<xsd:pattern value="[^\n\r\t]*"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="n-kanatype">
		<xsd:restriction base="gen:n-kana">
			<xsd:pattern value="[^\n\r\t]*"/>
