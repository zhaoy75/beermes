<xsd:appinfo>"(8)"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
</xsd:sequence>
</xsd:complexType>
</xsd:element>
<xsd:element name="LYB00120" type="gen:kingaku" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"(9)*90/100"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="LYB00130" type="gen:kingaku" minOccurs="0">
