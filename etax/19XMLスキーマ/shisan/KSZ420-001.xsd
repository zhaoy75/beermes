</xsd:annotation>
</xsd:element>
<xsd:element name="CJF00030" type="CJF00030-1-1type" minOccurs="0">
<xsd:annotation>
<xsd:appinfo>"面積"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
</xsd:sequence>
</xsd:complexType><xsd:complexType name="CJH00000-1-1type">
