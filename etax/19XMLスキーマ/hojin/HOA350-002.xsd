<xsd:appinfo>"措法第63条第3項第2号から第6号までの該当号　措法第68条の69第3項第2号から第6号までの該当号"</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element name="AMB00020" type="gen:yymmdd" minOccurs="0">
